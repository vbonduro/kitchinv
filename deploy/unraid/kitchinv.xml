<?xml version="1.0"?>
<Container version="2">
  <Name>kitchinv</Name>
  <Repository>ghcr.io/vbonduro/kitchinv</Repository>
  <Registry>https://ghcr.io</Registry>
  <Network>bridge</Network>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/vbonduro/kitchinv/issues</Support>
  <Project>https://github.com/vbonduro/kitchinv</Project>
  <Overview>Home kitchen inventory manager. Photograph your fridge, freezer, and pantry — kitchinv extracts a searchable food inventory from each photo using a vision AI model.</Overview>
  <Category>Productivity:</Category>
  <WebUI>http://[IP]:[PORT:8080]/</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/vbonduro/kitchinv/main/deploy/unraid/kitchinv.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/vbonduro/kitchinv/main/deploy/unraid/icon.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Description>Home kitchen inventory manager. Photograph your fridge, freezer, and pantry — kitchinv extracts a searchable food inventory from each photo using a vision AI model.</Description>
  <Networking>
    <Mode>bridge</Mode>
    <Publish>
      <Port>
        <HostPort>8080</HostPort>
        <ContainerPort>8080</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
    </Publish>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/kitchinv/data</HostDir>
      <ContainerDir>/data</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
    <Volume>
      <HostDir>/mnt/user/appdata/kitchinv/secrets</HostDir>
      <ContainerDir>/secrets</ContainerDir>
      <Mode>ro</Mode>
    </Volume>
  </Data>
  <Environment>
    <Variable>
      <Value>gemini</Value>
      <Name>VISION_BACKEND</Name>
      <Mode/>
    </Variable>
    <Variable>
      <Value>/secrets/gemini_key</Value>
      <Name>GEMINI_API_KEY_FILE</Name>
      <Mode/>
    </Variable>
    <Variable>
      <Value>gemini-2.5-flash</Value>
      <Name>GEMINI_MODEL</Name>
      <Mode/>
    </Variable>
    <Variable>
      <Value>/data/kitchinv.db</Value>
      <Name>DB_PATH</Name>
      <Mode/>
    </Variable>
    <Variable>
      <Value>/data/photos</Value>
      <Name>PHOTO_LOCAL_PATH</Name>
      <Mode/>
    </Variable>
    <Variable>
      <Value>:8080</Value>
      <Name>LISTEN_ADDR</Name>
      <Mode/>
    </Variable>
  </Environment>
  <Labels/>
</Container>
